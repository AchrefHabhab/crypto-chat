generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["crypto_chat"]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  publicKey     String?
  keyFingerprint String?
  accounts      Account[]
  sessions      Session[]
  rooms         RoomMember[]
  messages      Message[]
  reactions     Reaction[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@schema("crypto_chat")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@schema("crypto_chat")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("crypto_chat")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@schema("crypto_chat")
}

model Room {
  id          String       @id @default(cuid())
  name        String
  type        String       @default("group")
  inviteCode  String?      @unique @default(cuid())
  members     RoomMember[]
  messages    Message[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@schema("crypto_chat")
}

model RoomMember {
  id         String   @id @default(cuid())
  userId     String
  roomId     String
  role       String   @default("member")
  joinedAt   DateTime @default(now())
  lastReadAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@index([roomId])
  @@schema("crypto_chat")
}

model Message {
  id         String     @id @default(cuid())
  roomId     String
  senderId   String
  ciphertext String
  iv         String
  signature  String
  prevHash   String
  hash       String
  fileUrl    String?
  fileName   String?
  fileType   String?
  reactions  Reaction[]
  createdAt  DateTime   @default(now())
  room       Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender     User       @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([senderId])
  @@schema("crypto_chat")
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@schema("crypto_chat")
}
